    "db:seed:remote": "wrangler d1 execute publicist --file=seed.sql"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250508.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.0.0"
  }
}
